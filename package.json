{
  "name": "pvp-game-server",
  "version": "3.0.0",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd client && npm run build",
    "dev:client": "cd client && npm run dev"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.0",
    "@colyseus/ws-transport": "^0.15.0",
    "@dimforge/rapier3d-compat": "^0.12.0",
    "colyseus": "^0.15.0",
    "express": "^4.18.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  },
  "optionalDependencies": {
    "@colyseus/monitor": "^0.15.0",
    "@colyseus/uwebsockets-transport": "^0.15.0"
  },
  "_packageNotes": {
    "versionPolicy": "All @colyseus/* packages MUST share the same minor version (all 0.15.x). Mixing 0.14.x and 0.15.x breaks the seat reservation handshake.",
    "clientSide": "npm install colyseus.js@^0.15.0 @dimforge/rapier3d-compat three"
  }
}
