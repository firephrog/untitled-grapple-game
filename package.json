{
  "name": "pvp-game-server",
  "version": "3.0.0",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node --max-semi-space-size=16 --expose-gc server.js",
    "dev": "nodemon --exec \"node --max-semi-space-size=16 --expose-gc\" server.js",
    "build": "cd client && npm run build",
    "dev:client": "cd client && npm run dev",
    "test": "npm run build && node --max-semi-space-size=16 --expose-gc server.js",
    "cloudflareBuild": "cd client && npm install && cd .. && npm run build",
    "cpp:build": "cd cpp-server && cargo build --release && cmake -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build --config Release",
    "cpp:dev": "cd cpp-server && cargo build && cmake -B build && cmake --build build",
    "cpp:run": "cpp-server/build-ninja/ugg-server.exe",
    "launch": "powershell -ExecutionPolicy Bypass -File start.ps1",
    "launch:dev": "powershell -ExecutionPolicy Bypass -File start.ps1 -Client"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.0",
    "@colyseus/ws-transport": "^0.15.0",
    "@grpc/grpc-js": "^1.11.0",
    "@grpc/proto-loader": "^0.7.13",
    "bcryptjs": "^3.0.3",
    "colyseus": "^0.15.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.2",
    "nodemon": "^3.0.0",
    "wrangler": "^4.85.0"
  },
  "optionalDependencies": {
    "@colyseus/monitor": "^0.15.0",
    "@colyseus/uwebsockets-transport": "^0.15.0"
  },
  "_packageNotes": {
    "versionPolicy": "All @colyseus/* packages MUST share the same minor version (all 0.15.x). Mixing 0.14.x and 0.15.x breaks the seat reservation handshake.",
    "clientSide": "npm install colyseus.js@^0.15.0 @dimforge/rapier3d-compat three"
  }
}
