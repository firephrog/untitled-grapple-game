{
  "configurations": [
    {
      "name": "Windows (cpp-server)",
      "intelliSenseMode": "windows-msvc-x64",
      "cppStandard": "c++17",

      // compile_commands.json is generated by the Ninja build (build-ninja/).
      // Regenerate with:
      //   cmd /c "call vcvars64.bat && set PATH=%PATH%;<ninja-dir> && cd cpp-server && cmake -G Ninja -B build-ninja -DCMAKE_TOOLCHAIN_FILE=C:/vcpkg/scripts/buildsystems/vcpkg.cmake -DVCPKG_TARGET_TRIPLET=x64-windows -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_COMPILER=<msvc-x64-cl> && cmake --build build-ninja"
      "compileCommands": "${workspaceFolder}/cpp-server/build-ninja/compile_commands.json",

      // Fallback paths used until compile_commands.json exists.
      "includePath": [
        "${workspaceFolder}/cpp-server/src",
        "${workspaceFolder}/cpp-server/src/systems",
        "${workspaceFolder}/cpp-server/src/physics",

        // protobuf/gRPC stub headers (generated at build time)
        "${workspaceFolder}/cpp-server/build-ninja/proto_generated",
        "${workspaceFolder}/cpp-server/build/proto_generated",

        // cxx Rapier bridge header (generated by `cargo build`)
        "${workspaceFolder}/cpp-server/target/cxxbridge",

        // vcpkg — all installed headers (x64-windows triplet)
        "C:/vcpkg/installed/x64-windows/include",

        "${default}"
      ],

      "defines": [
        "_DEBUG",
        "UNICODE",
        "_UNICODE"
      ]
    }
  ],
  "version": 4
}
